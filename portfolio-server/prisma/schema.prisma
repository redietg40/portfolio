// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}
model About {
  id Int @id @default(autoincrement())
  text String
}

model Skill {
  id          Int @id @default(autoincrement())
  name        String
  percentage  Int
  icon        String
  category String  
}

model Project {
  id          Int    @id @default(autoincrement())
  name        String
  description String
  liveUrl     String
  image       String
  githubUrl   String?
}
model Contact {
  id        Int      @id @default(autoincrement())
  email     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}